CENTURION_API_KEY=your-centurion-api-key
CENTURION_API_BASE=https://api-gateway.centurionpaybr.com
# Opcional: defina uma URL publica se quiser receber webhooks em outro endpoint.
# CENTURION_POSTBACK_URL=https://seu-dominio.com/api/centurion/webhook

# Track7 (logistica)
TRACK7_API_KEY=your-track7-api-key
# Opcional: default https://track7.app/api/v1
# TRACK7_BASE_URL=https://track7.app/api/v1

# Dashboard interno de funil
# Defina uma chave para proteger /dashboard.html e /api/metrics/summary.
DREE_DASHBOARD_KEY=sua-chave-interna

# Persistencia das metricas em producao.
# Crie um Redis/KV na Vercel ou Upstash e copie as variaveis REST abaixo.
KV_REST_API_URL=https://seu-redis.upstash.io
KV_REST_API_TOKEN=seu-token-rest
